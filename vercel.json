{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install --no-audit --no-fund",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemaps/(.*).xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(dashboard|account|checkout|auth|purchase-success|success|admin|admin-v2)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/org/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "redirects": [
    { "source": "/berufski/:path*", "destination": "/work", "statusCode": 410 }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/sitemap.xml", "destination": "https://ubdvvvsiryenhrfmqsvw.supabase.co/functions/v1/generate-sitemap" },
    { "source": "/sitemaps/:shard.xml", "destination": "https://ubdvvvsiryenhrfmqsvw.supabase.co/functions/v1/generate-sitemap?type=:shard" },

    { "source": "/berufe", "destination": "/berufe/index.html" },
    { "source": "/berufe/einzelhandelskaufmann-frau", "destination": "/berufe/einzelhandelskaufmann-frau/index.html" },
    { "source": "/berufe/kaufmann-frau-bueromanagement", "destination": "/berufe/kaufmann-frau-bueromanagement/index.html" },
    { "source": "/berufe/industriekaufmann-frau", "destination": "/berufe/industriekaufmann-frau/index.html" },
    { "source": "/berufe/fachinformatiker-systemintegration", "destination": "/berufe/fachinformatiker-systemintegration/index.html" },
    { "source": "/berufe/kfz-mechatroniker-in", "destination": "/berufe/kfz-mechatroniker-in/index.html" },
    { "source": "/preise", "destination": "/preise/index.html" },
    { "source": "/produkte", "destination": "/produkte/index.html" },
    { "source": "/faq", "destination": "/faq/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/courses", "destination": "/courses/index.html" },
    { "source": "/lernkurse", "destination": "/lernkurse/index.html" },
    { "source": "/bilanzbuchhalter-buchhaltung", "destination": "/bilanzbuchhalter-buchhaltung/index.html" },
    { "source": "/bilanzbuchhalter-jahresabschluss", "destination": "/bilanzbuchhalter-jahresabschluss/index.html" },
    { "source": "/bilanzbuchhalter-pruefungsvorbereitung", "destination": "/bilanzbuchhalter-pruefungsvorbereitung/index.html" },
    { "source": "/bilanzbuchhalter-steuern", "destination": "/bilanzbuchhalter-steuern/index.html" },
    { "source": "/fiae-anwendungsentwicklung", "destination": "/fiae-anwendungsentwicklung/index.html" },
    { "source": "/fiae-projektarbeit", "destination": "/fiae-projektarbeit/index.html" },
    { "source": "/fiae-pruefungsvorbereitung", "destination": "/fiae-pruefungsvorbereitung/index.html" },
    { "source": "/fiae-wiso", "destination": "/fiae-wiso/index.html" },
    { "source": "/pruefungstraining-azubis", "destination": "/pruefungstraining-azubis/index.html" },
    { "source": "/pruefungstraining-betriebe", "destination": "/pruefungstraining-betriebe/index.html" },
    { "source": "/pruefungstraining-institutionen", "destination": "/pruefungstraining-institutionen/index.html" },

    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
